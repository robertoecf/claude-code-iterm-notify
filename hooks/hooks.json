{
  "description": "macOS notifications with sound and voice alerts when Claude Code needs attention. Identifies iTerm2 sessions by profile name.",
  "hooks": {
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PLUGIN_ROOT/hooks/scripts/notify.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PLUGIN_ROOT/hooks/scripts/notify.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
